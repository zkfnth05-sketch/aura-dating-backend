
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // matches 컬렉션 규칙
    match /matches/{matchId} {
      // 로그인한 유저이고, 해당 매치의 users 배열에 본인 ID가 있는 경우에만 허용
      allow read, update: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null;

      // 하위 컬렉션 (messages, candidates 등)에 대한 접근 권한
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    // 유저 정보 읽기 규칙
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 좋아요 기능은 그대로 유지합니다.
    match /likes/{likeId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.likerId == request.auth.uid;
        allow update, delete: if false;
    }
    
    match /reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
