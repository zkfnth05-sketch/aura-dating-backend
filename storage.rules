rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // By default, deny all reads and writes unless specified below.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to read any file. 
    // This is needed so users can see/hear each other's content.
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Allow authenticated users to upload audio messages to a chat.
    match /audio_messages/{matchId}/{fileName} {
      allow write: if request.auth != null;
    }

    // Allow a user to upload videos only to their own folder.
    match /videos/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
