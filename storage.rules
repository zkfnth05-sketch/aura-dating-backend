rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default: Allow authenticated users to read anything, but deny all writes.
    // Specific write rules below will grant access where needed.
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Allow any authenticated user to upload audio messages to a chat.
    match /audio_messages/{matchId}/{fileName} {
      allow write: if request.auth != null;
    }

    // Allow a user to upload videos only to their own folder.
    match /videos/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
