
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the primary function for checking resource ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the current user is one of the participants in a given match document.
     */
    function isMatchParticipant(matchDoc) {
      return isSignedIn() && request.auth.uid in matchDoc.data.users;
    }

    // --------------------------------
    // User Data Collections
    // --------------------------------

    // 유저 정보 읽기 규칙
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // --------------------------------
    // Shared Data Collections
    // --------------------------------

    /**
     * @description Rules for the top-level 'likes' collection.
     */
    match /likes/{likeId} {
        // Anyone signed in can read the likes, necessary for querying.
        allow read: if isSignedIn();
        // A user can only create a like document if the 'likerId' in the document
        // is their own user ID. This prevents spoofing.
        allow create: if isSignedIn() && request.resource.data.likerId == request.auth.uid;
        // Likes are immutable, they cannot be updated or deleted by clients.
        allow update, delete: if false;
    }


    // matches 컬렉션 규칙
    match /matches/{matchId} {
      // 로그인한 유저이고, 해당 매치의 users 배열에 본인 ID가 있는 경우에만 허용
      allow read, update: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null;
      
      // 하위 컬렉션 (messages, candidates 등)에 대한 접근 권한
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    /**
     * @description Rules for the top-level 'reports' collection.
     */
    match /reports/{reportId} {
      // Any signed-in user can create a report, but they must be the reporter.
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      // Only backend processes should read/update/delete reports.
      allow read, update, delete: if false;
    }
  }
}
