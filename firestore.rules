rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() { return request.auth != null; }

    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --------------------------------
    // User Data Collections
    // --------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
    
    // --------------------------------
    // Shared Data Collections
    // --------------------------------

    match /likes/{likeId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.likerId || request.auth.uid == resource.data.likeeId);
      allow create: if isSignedIn() && request.resource.data.likerId == request.auth.uid;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      // Allow a user to list only the matches they are a part of.
      allow list: if isSignedIn() && request.query.where.users.includes(request.auth.uid);
      
      // Allow a user to get, update, or create a match document if they are a participant.
      allow get, update: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users;

      // Allow participants to manage WebRTC signaling and chat messages.
      match /candidates/{candidateId} {
        allow read, write, delete: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
      }
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
      }
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
