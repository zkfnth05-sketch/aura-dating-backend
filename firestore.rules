
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the primary function for checking resource ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the current user is one of the participants in a given match document.
     */
    function isMatchParticipant(matchDoc) {
      return isSignedIn() && request.auth.uid in matchDoc.data.users;
    }

    // --------------------------------
    // User Data Collections
    // --------------------------------

    /**
     * @description Users can create their own profile. Authenticated users can read/list profiles.
     * Only the owner can update/delete their own profile.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      // Allow any signed-in user (like an admin) to create a new user document.
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // --------------------------------
    // Shared Data Collections
    // --------------------------------

    /**
     * @description Rules for the top-level 'likes' collection.
     */
    match /likes/{likeId} {
        // Anyone signed in can read the likes, necessary for querying.
        allow read: if isSignedIn();
        // A user can only create a like document if the 'likerId' in the document
        // is their own user ID. This prevents spoofing.
        allow create: if isSignedIn() && request.resource.data.likerId == request.auth.uid;
        // Likes are immutable, they cannot be updated or deleted by clients.
        allow update, delete: if false;
    }


    /**
     * @description Match documents can be read by participants. Creation is handled client-side for prototype.
     */
    match /matches/{matchId} {
      // Only participants can read or update a match document.
      // For `list` operations, the client query must be secured with a `where('users', 'array-contains', ...)` clause.
      allow read, list, update: if isSignedIn() && request.auth.uid in resource.data.users;
      
      // Allow authenticated users to create matches (for prototyping).
      allow create: if isSignedIn();
      
      // Prevent clients from deleting matches.
      allow delete: if false;

      /**
       * @description Messages subcollection rules.
       */
      match /messages/{messageId} {
        // The `list` rule is simplified to `isSignedIn()`. Security relies on the fact 
        // that only participants can know the parent `matchId` in the first place,
        // as enforced by the rules on the `matches` collection itself.
        allow list: if isSignedIn();
        
        // Reading a single message still requires being a participant.
        allow get: if isMatchParticipant(get(/databases/$(database)/documents/matches/$(matchId)));
        
        // Users can only create messages as themselves (or system messages).
        allow create: if isMatchParticipant(get(/databases/$(database)/documents/matches/$(matchId))) 
                      && (request.resource.data.senderId == request.auth.uid || request.resource.data.senderId == 'system');

        // Messages are immutable.
        allow update: if false;
        
        // Users can only delete their own messages.
        allow delete: if isMatchParticipant(get(/databases/$(database)/documents/matches/$(matchId))) 
                      && resource.data.senderId == request.auth.uid;
      }

      /**
       * @description WebRTC signaling candidates for video calls.
       * The `write` rule is simplified to fix permission errors during call cleanup.
       * Security is maintained as only participants can access this path.
       */
      match /candidates/{candidateId} {
        allow read, write: if isMatchParticipant(get(/databases/$(database)/documents/matches/$(matchId)));
      }
    }

    /**
     * @description Rules for the top-level 'reports' collection.
     */
    match /reports/{reportId} {
      // Any signed-in user can create a report, but they must be the reporter.
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      // Only backend processes should read/update/delete reports.
      allow read, update, delete: if false;
    }
  }
}
